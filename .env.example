# ─────────────────────────────────────────────────────────────
# Commission Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# PostgreSQL is required for any cloud deployment (Vercel, Render, etc.)
# SQLite is only safe for local development — /tmp is ephemeral in serverless.
#
# Supabase (Transaction Pooler — port 6543 for serverless):
#   DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Render managed PostgreSQL:
#   DATABASE_URL=postgresql://user:password@host/dbname
#
# Local SQLite (development only):
#   DATABASE_URL=sqlite+aiosqlite:////tmp/commission.db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Supabase Auth ─────────────────────────────────────────────
# Required to enable email/password sign-up, magic links, and password reset.
# Find these in your Supabase project → Settings → API.
# Leave blank to fall back to legacy username/password auth.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Application ───────────────────────────────────────────────
# Full public URL of your deployment (used in password-reset emails, OAuth redirects).
# No trailing slash.
APP_URL=https://your-app.vercel.app

# ── Optional integrations ─────────────────────────────────────
# Anthropic API key — only needed if you use AI features in the app.
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API key — used for dealership address autocomplete (Phase 2).
GOOGLE_PLACES_API_KEY=AIza...
